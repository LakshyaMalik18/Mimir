# Streamlit Community Cloud secrets — copy into the app's Secrets settings
# (or to .streamlit/secrets.toml for local runs). NEVER commit real values.
#
# Only used when the app runs OUTSIDE Databricks. Inside a Databricks App,
# ambient service-principal auth is used and none of these are read.

# Workspace URL, including https://
DATABRICKS_HOST = "https://your-workspace.cloud.databricks.com"

# Personal access token (User Settings -> Developer -> Access tokens)
DATABRICKS_TOKEN = "dapi-your-personal-access-token"

# SQL warehouse HTTP path (SQL Warehouses -> your warehouse -> Connection details)
DATABRICKS_HTTP_PATH = "/sql/1.0/warehouses/your-warehouse-id"

# Optional: kill-switch fallback for AI receipts if the Databricks
# serving endpoint is unavailable
# OPENAI_API_KEY = "sk-your-openai-key"
